# Copy to .env.local and fill in from your Supabase project settings
# (Settings → API). Also add all three to the Vercel project env for deploys.

# Client (Vite) — used by the frontend SDK. Safe to expose (anon key).
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Server only — used by the /api/parse-receipt function for receipt OCR.
# NEVER prefix with VITE_ and never expose to the client.
ANTHROPIC_API_KEY=YOUR-ANTHROPIC-KEY

# Without VITE_SUPABASE_* the app runs in a local, in-memory DEMO mode
# (seeded data, mocked receipt parsing) so you can explore the whole UI offline.
